#!/bin/bash

# ==============================================================================
# Script di Installazione per zeroCAM
# ==============================================================================
# Questo script automatizza l'installazione di zeroCAM su sistemi basati su
# Debian, come Raspberry Pi OS.
# ==============================================================================

set -e # Esce immediatamente se un comando fallisce

# --- Variabili di Configurazione ---
INSTALL_DIR="/usr/local/zerocam"
APP_DIR="$INSTALL_DIR/app"
VENV_DIR="$INSTALL_DIR/venv"

# --- Funzioni di Utility per l'Output ---
echo_step() {
    echo " "
    echo "=============================================================================="
    echo "➡️  $1"
    echo "=============================================================================="
}

echo_info() {
    echo "   [INFO] $1"
}

echo_success() {
    echo "   [SUCCESS] $1"
}

echo_warning() {
    echo "   [WARNING] $1"
}

# Controlla se lo script è eseguito come root
if [ "$(id -u)" -ne 0 ]; then
    echo "Questo script deve essere eseguito con i privilegi di sudo."
    exit 1
fi

# Chiede la versione da installare
echo_step "Benvenuto nell'installatore di zeroCAM"
read -p "Inserisci il tag della versione da installare (es. v0.0.1): " RELEASE_TAG
if [ -z "$RELEASE_TAG" ]; then
    echo "Il tag della versione non può essere vuoto. Uscita."
    exit 1
fi
RELEASE_URL="https://github.com/iz1kga/zeroCam/releases/download/${RELEASE_TAG}/zeroCam_${RELEASE_TAG}.zip"

# Passo 1: Installazione delle dipendenze di sistema
# ==============================================================================
echo_step "Passo 1: Installazione delle dipendenze di sistema..."
apt-get update
apt-get install -y \
    build-essential libcap-dev python3-dev python3-setuptools python3-venv \
    libsoup2.4-1 libsoup-gnome2.4-1 vim libcamera-apps libcamera-dev \
    python3-libcamera gir1.2-gst-rtsp-server-1.0 python3-picamera2 gstreamer1.0-tools \
    gstreamer1.0-plugins-bad gstreamer1.0-libcamera gstreamer1.0-rtsp \
    gstreamer1.0-plugins-good gstreamer1.0-plugins-base python3-gi \
    python3-gst-1.0 gstreamer1.0-plugins-ugly gstreamer1.0-libav wireguard \
    ffmpeg libcamera-tools wget unzip jq openssl uuid-runtime
echo_success "Dipendenze di sistema installate."

# Passo 2: Arresto del servizio esistente (se presente)
# ==============================================================================
echo_step "Passo 2: Controllo e arresto del servizio zeroCAM esistente..."
if systemctl list-units --type=service | grep -q "zerocam.service"; then
    if systemctl is-active --quiet zerocam.service; then
        echo_info "Servizio zeroCAM trovato e in esecuzione. Lo fermo..."
        systemctl stop zerocam.service
        echo_success "Servizio zeroCAM arrestato."
    else
        echo_info "Servizio zeroCAM trovato ma non in esecuzione."
    fi
else
    echo_info "Nessun servizio zeroCAM esistente trovato. Proseguo."
fi

# Passo 3: Creazione della directory di installazione
# ==============================================================================
echo_step "Passo 3: Creazione della directory di installazione..."
mkdir -p "$INSTALL_DIR"
if [ -n "$SUDO_USER" ]; then
    chown -R "$SUDO_USER:$SUDO_USER" "$INSTALL_DIR"
    echo_success "Proprietario di $INSTALL_DIR impostato a $SUDO_USER."
else
    echo_warning "Impossibile determinare l'utente. I permessi potrebbero richiedere aggiustamenti manuali."
fi

# Passo 4: Creazione dell'ambiente virtuale Python
# ==============================================================================
echo_step "Passo 4: Creazione dell'ambiente virtuale Python..."
if [ -d "$VENV_DIR" ]; then
    echo_info "Ambiente virtuale già esistente. Lo riutilizzo."
else
    sudo -u "$SUDO_USER" python3 -m venv "$VENV_DIR" --system-site-packages
    echo_success "Ambiente virtuale creato in $VENV_DIR."
fi

# Passo 5: Backup e pulizia di una eventuale installazione precedente
# ==============================================================================
echo_step "Passo 5: Gestione di installazioni precedenti..."
if [ -d "$APP_DIR" ]; then
    echo_warning "Trovata un'installazione precedente. Eseguo il backup della configurazione."
    BACKUP_DIR="$INSTALL_DIR/backup_$(date +%Y%m%d%H%M%S)"
    mkdir -p "$BACKUP_DIR"
    
    # Esegue l'unmount di shmem se necessario
    if mountpoint -q "$APP_DIR/shmem"; then
        echo_info "Eseguo l'unmount di $APP_DIR/shmem..."
        umount "$APP_DIR/shmem"
        echo_success "Unmount completato."
    fi

    if [ -f "$APP_DIR/.conf.json" ]; then
        mv "$APP_DIR/.conf.json" "$BACKUP_DIR/"
        echo_success "Backup di .conf.json eseguito."
    fi
    if [ -f "$APP_DIR/.privacy_mask.json" ]; then
        mv "$APP_DIR/.privacy_mask.json" "$BACKUP_DIR/"
        echo_success "Backup di .privacy_mask.json eseguito."
    fi
    if [ -f "$APP_DIR/.env" ]; then
        mv "$APP_DIR/.env" "$BACKUP_DIR/"
        echo_success "Backup di .env eseguito."
    fi
    rm -rf "$APP_DIR"
    echo_info "Vecchia directory dell'applicazione rimossa."
fi

# Passo 6: Download ed estrazione dell'applicazione
# ==============================================================================
echo_step "Passo 6: Download ed estrazione di zeroCAM $RELEASE_TAG..."
mkdir -p "$APP_DIR"
TEMP_ZIP=$(mktemp)
wget -O "$TEMP_ZIP" "$RELEASE_URL"
unzip "$TEMP_ZIP" -d "$APP_DIR"
rm "$TEMP_ZIP"
echo_success "Applicazione estratta in $APP_DIR."

# Passo 7: Ripristino della configurazione dal backup
# ==============================================================================
echo_step "Passo 7: Ripristino della configurazione..."
BACKUP_DIR_LATEST=$(ls -td -- "$INSTALL_DIR"/backup_* 2>/dev/null | head -n 1)
if [ -d "$BACKUP_DIR_LATEST" ]; then
    # Ripristina .env
    if [ -f "$BACKUP_DIR_LATEST/.env" ]; then
        mv "$BACKUP_DIR_LATEST/.env" "$APP_DIR/"
        echo_success "File .env ripristinato."
    fi
    # Ripristina .privacy_mask.json
    if [ -f "$BACKUP_DIR_LATEST/.privacy_mask.json" ]; then
        mv "$BACKUP_DIR_LATEST/.privacy_mask.json" "$APP_DIR/"
        echo_success "File .privacy_mask.json ripristinato."
    fi
    # Unisce .conf.json
    if [ -f "$BACKUP_DIR_LATEST/.conf.json" ]; then
        TEMP_MERGED=$(mktemp)
        jq -s '.[0] * .[1]' "$APP_DIR/.conf.json" "$BACKUP_DIR_LATEST/.conf.json" > "$TEMP_MERGED"
        mv "$TEMP_MERGED" "$APP_DIR/.conf.json"
        echo_success "File .conf.json unito e ripristinato."
    fi
fi
chown -R "$SUDO_USER:$SUDO_USER" "$APP_DIR"

# Passo 8: Configurazione della memoria condivisa (tmpfs)
# ==============================================================================
echo_step "Passo 8: Configurazione della memoria condivisa (tmpfs)..."
mkdir -p "$APP_DIR/shmem"
chown "$SUDO_USER:$SUDO_USER" "$APP_DIR/shmem" # Assicura la proprietà corretta
FSTAB_LINE="tmpfs $APP_DIR/shmem tmpfs defaults,noatime,nosuid,size=25M 0 0"
if ! grep -qF "$FSTAB_LINE" /etc/fstab; then
    echo "$FSTAB_LINE" >> /etc/fstab
    echo_success "Riga tmpfs aggiunta a /etc/fstab."
fi
mount -a
echo_success "Mountpoint attivati."

# Passo 9: Installazione delle dipendenze Python
# ==============================================================================
echo_step "Passo 9: Installazione delle dipendenze Python..."
if [ -f "$APP_DIR/requirements.txt" ]; then
    sudo -u "$SUDO_USER" "$VENV_DIR/bin/pip" install -r "$APP_DIR/requirements.txt"
    echo_success "Dipendenze Python installate."
else
    echo_warning "File requirements.txt non trovato."
fi

# Passo 10: Configurazione iniziale e sicurezza
# ==============================================================================
echo_step "Passo 10: Configurazione iniziale e sicurezza..."

ENV_FILE="$APP_DIR/.env"

if [ ! -f "$ENV_FILE" ]; then
    echo_info "File .env non trovato. Lo creo da zero..."
    DEVICE_ID=$(uuidgen)
    ZEROCAM_SECRET_KEY=$(openssl rand -hex 32)
    sudo -u "$SUDO_USER" bash -c "cat > '$ENV_FILE' <<EOL
DEVICE_ID=$DEVICE_ID
ZEROCAM_SECRET_KEY=$ZEROCAM_SECRET_KEY
EOL"
    chmod 600 "$ENV_FILE"
    echo_success "File .env creato con successo."
else
    echo_info "File .env esistente. Verifico le chiavi..."
    if ! grep -q "^DEVICE_ID=" "$ENV_FILE"; then
        echo_info "DEVICE_ID mancante. Lo genero e lo aggiungo."
        DEVICE_ID=$(uuidgen)
        echo "DEVICE_ID=$DEVICE_ID" >> "$ENV_FILE"
    else
        echo_success "DEVICE_ID già presente."
    fi
    if ! grep -q "^ZEROCAM_SECRET_KEY=" "$ENV_FILE"; then
        echo_info "ZEROCAM_SECRET_KEY mancante. La genero e la aggiungo."
        ZEROCAM_SECRET_KEY=$(openssl rand -hex 32)
        echo "ZEROCAM_SECRET_KEY=$ZEROCAM_SECRET_KEY" >> "$ENV_FILE"
    else
        echo_success "ZEROCAM_SECRET_KEY già presente."
    fi
fi

# Controlla se la password è già impostata nel file .conf.json
PASSWORD_SET="false"
if [ -f "$APP_DIR/.conf.json" ]; then
    PASSWORD_SET=$(jq 'if .security and .security.password and (.security.password | length > 0) then true else false end' "$APP_DIR/.conf.json")
fi

if [ "$PASSWORD_SET" != "true" ]; then
    echo_info "Impostazione della password dell'applicazione..."
    while true; do
        read -s -p "Inserisci una nuova password: " PASSWORD
        echo
        read -s -p "Conferma la password: " PASSWORD_CONFIRM
        echo
        if [ "$PASSWORD" = "$PASSWORD_CONFIRM" ]; then
            break
        else
            echo "Le password non coincidono. Riprova."
        fi
    done
    PASSWORD_HASH=$("$VENV_DIR/bin/python" -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('$PASSWORD'))")
    jq ".security.password = \"$PASSWORD_HASH\"" "$APP_DIR/.conf.json" > "${APP_DIR}/.conf.json.tmp" && mv "${APP_DIR}/.conf.json.tmp" "$APP_DIR/.conf.json"
    chown "$SUDO_USER:$SUDO_USER" "$APP_DIR/.conf.json" # Assicura la proprietà corretta dopo la modifica
    echo_success "Password dell'applicazione impostata e salvata."
else
    echo_info "Una password per l'applicazione è già impostata. Salto questo passaggio."
fi

# Passo 11: Configurazione di sudo per il riavvio senza password
# ==============================================================================
echo_step "Passo 11: Configurazione di sudo per il riavvio..."
SUDOERS_FILE="/etc/sudoers.d/010_zerocam-reboot"
if [ ! -f "$SUDOERS_FILE" ]; then
    echo "$SUDO_USER ALL=(ALL) NOPASSWD: /sbin/reboot" > "$SUDOERS_FILE"
    chmod 440 "$SUDOERS_FILE"
    echo_success "Regola sudoers per il riavvio creata."
else
    echo_info "Regola sudoers per il riavvio già presente."
fi

# Passo 12: Creazione e avvio del servizio systemd
# ==============================================================================
echo_step "Passo 12: Creazione e avvio del servizio systemd..."
SERVICE_FILE="/etc/systemd/system/zerocam.service"
cat > "$SERVICE_FILE" <<EOL
[Unit]
Description=zeroCAM Service
After=network.target

[Service]
User=$SUDO_USER
Group=$SUDO_USER
WorkingDirectory=$APP_DIR
EnvironmentFile=$APP_DIR/.env
ExecStart=$VENV_DIR/bin/python zeroCam.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOL

systemctl daemon-reload
systemctl enable zerocam.service
systemctl start zerocam.service

echo_success "Servizio zeroCAM creato, abilitato e avviato."
echo_step "Installazione completata!"

